{
  "name": "mem",
  "version": "0.1.0",
  "type": "module",
  "description": "Agentic memory benchmarked on Gas City orchestration traces — work-audit graph builder",
  "bin": {
    "mem": "./bin/mem"
  },
  "files": [
    "bin/",
    "dist/"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest --run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"bin/**/*\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\" \"bin/**/*\"",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm test"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^8.46.3",
    "@typescript-eslint/parser": "^8.46.3",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "prettier": "^3.6.2",
    "typescript": "^5.3.3",
    "vitest": "^1.0.4"
  }
}
