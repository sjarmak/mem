// The `mem` work-audit graph + agentic-memory benchmark.
//
// Two halves: a TypeScript store builder/server (src/) and a Python eval
// harness (memory-bench/). Planned and research work is tagged so it renders
// distinctly from what is already built (see spec.c4 for the tag legend).
//
// Elements carry `link`s to their source and to the relevant entry in the
// chronological decision log (docs/architecture-decisions.md), so a reviewer
// can jump from any box to the code and the rationale behind it.

model {

  agent = actor 'Agent under test' {
    description 'Coding agent whose runs are replayed and measured across memory conditions'
  }

  // ─────────────────────────────────────────────────────────────────────────
  // External systems — the audit substrate and execution/inference services.
  // The benchmark runs on TWO corpora: the orchestrator's own real audit (the
  // headline substrate) and a seed-reproducible synthetic-world track
  // (generators/, the source of the first measurable lift) materialized in
  // the harness from a frozen NeMo natural-language surface.
  // ─────────────────────────────────────────────────────────────────────────

  gascity = externalSystem 'Multi-agent orchestrator' {
    description 'Runs agents across 18 project rigs — produces the audit corpus'

    beadStore = datastore 'Work-item store' {
      description 'The work spine: 6,691 items (id, status, assignee, labels, deps, convoy)'
    }
    sessionTraces = datastore 'Session traces (JSONL)' {
      description '874 resolved transcripts: tool calls, outputs, decisions, errors'
    }
    gcLogs = externalSystem 'Session-log resolver' {
      description 'Maps an assignee/session id to its transcript JSONL path'
    }
  }

  github = externalSystem 'GitHub' {
    description 'PRs / commits — the external outcome label, where a linkage exists'
  }

  harbor = externalSystem 'Harbor' {
    description 'Execution substrate that replays held-out tasks under each memory arm'
  }

  models = externalSystem 'Inference models' {
    description 'Semantic extractor, LLM-judge, and embedding models (OSS / self-hosted — no-paid-API constraint)'
  }

  nemo = externalSystem 'NeMo / local NIM' {
    description 'Natural-language surface for the synthetic-world generator; run offline against a local NIM, then frozen'
  }

  // ─────────────────────────────────────────────────────────────────────────
  // The mem system.
  // ─────────────────────────────────────────────────────────────────────────

  mem = system 'mem' {
    description 'Turns the work spine + transcripts into a work-audit graph, then benchmarks memory on it'
    link ../ARCHITECTURE.md 'Architecture overview'
    link ../docs/architecture-decisions.md 'Decision log (1–18)'

    // ── TypeScript half: builds and serves the store ───────────────────────
    store = container 'Store builder & server' {
      description 'src/ — ingest → parse → store → retrieve → distill, exposed through the mem CLI'
      technology 'TypeScript / Node'
      link ../src 'src/'

      ingest = component 'ingest/' {
        #built
        description 'Source readers → raw WorkRecords (pure IO)'
        link ../src/ingest 'src/ingest/'

        beadReader = component 'beads + outcomes' {
          #built
          #risk
          description 'Reads the work spine and PR/commit outcomes. RISK: outcome linkage is structurally sparse (≈1 in 6,000 carries a usable external ref), which is why the headline is ablation-based, not merged-PR'
          link ../src/ingest/beads.ts 'beads.ts'
          link ../docs/architecture-decisions.md 'Decision 17 — ablation headline'
        }
        traceReader = component 'trace resolve + index' {
          #built
          description 'Resolves each session id to its JSONL and indexes turns/tool calls'
          link ../src/ingest/trace-resolve.ts 'trace-resolve.ts'
        }
        provenance = component 'provenance' {
          #built
          #risk
          description 'Session-start base commit (commit-by-date). RISK: gc never records the exact base SHA, so cleaner replay coverage depends on capturing each session’s true per-worktree base commit — a trace-substrate change, not a harness patch'
          link ../src/ingest/provenance.ts 'provenance.ts'
        }
        landed = component 'landed + commit-linkage (git-native oracle)' {
          #built
          #risk
          description 'Decision 18: the forward mirror of provenance — dates the branch tip at session close and takes the surviving in-window commits as the session’s landed work. The right outcome oracle for a direct-to-main corpus. RISK: in-repo session concurrency makes overlapping branch windows ambiguous (deterministically attributed at small N; the rest awaits author/SHA attribution)'
          link ../src/ingest/landed.ts 'landed.ts'
          link ../docs/architecture-decisions.md 'Decision 18 — direct-to-main git-native oracle'
        }
        repoResolve = component 'repo resolve (rig→repo map)' {
          #built
          description 'Canonical owner/name on every record; records how it resolved'
          link ../src/ingest/repo-resolve.ts 'repo-resolve.ts'
        }
      }

      parse = component 'parse/' {
        #built
        description 'Two extractors, kept strictly separate (the ZFC boundary)'
        link ../src/parse 'src/parse/'

        deterministic = component 'deterministic extractor' {
          #built
          description 'Tool exit states + file:line build/test/lint errors + cross-task recurrence math — in code, no keyword heuristics'
          link ../src/parse/error-extractors.ts 'error-extractors.ts'
        }
        semantic = component 'semantic extractor' {
          #evolving
          description 'Root-cause + resolution approach via a model — batched once per record, append-only'
          link ../src/parse/trace-parse.ts 'trace-parse.ts'
        }
      }

      graph = datastore 'store/ — SQLite + FTS5 sidecar' {
        #built
        description '.mem/store.db (schema v8). WorkRecord projection (rebuilt on upsert from the canonical record JSON) + append-only lessons + PROV-O links (T1/T2/T3)'
        link ../src/store/schema.ts 'schema.ts'
        link ../docs/architecture-decisions.md 'Decision 3 — append-only lessons'
      }

      retrieve = component 'retrieve/' {
        #built
        description 'Failure-triggered retrieval v1: keys on normalized file:line + error-class'
        link ../src/retrieve 'src/retrieve/'
        link ../docs/architecture-decisions.md 'Decision 8 — failure-triggered trigger'

        ranker = component 'retrieval + exclusions' {
          #built
          description 'Temporal leave-one-out + convoy/supersedes/PR-share exclusions enforced at read time'
          link ../src/retrieve/exclusions.ts 'exclusions.ts'
          link ../docs/architecture-decisions.md 'Decision 6 — temporal LOO + exclusions'
        }
        disclosure = component 'progressive disclosure' {
          #built
          description 'index → details --pick → full; agent sees token cost before hydrating'
          link ../src/retrieve/disclosure.ts 'disclosure.ts'
          link ../docs/architecture-decisions.md 'Decision 9 — distilled payload'
        }
      }

      distill = component 'distill/' {
        #evolving
        description 'Distills prior resolutions into retrievable lessons with citations (236 so far, dashboard rig)'
        link ../src/distill/distiller.ts 'distiller.ts'
      }

      cli = component 'bin/mem CLI' {
        #built
        description 'build-store, ingest-traces, query, retrieve, coverage, export/import-lessons — JSON envelope'
        link ../bin/mem 'bin/mem'
        link ../src/cli 'src/cli/'
      }
    }

    // ── Python half: the replay eval harness ───────────────────────────────
    bench = container 'memory-bench/ eval harness' {
      description 'Replays held-out tasks under no_memory / oracle / memory_enabled and reads the gaps'
      technology 'Python'
      link ../memory-bench 'memory-bench/'
      link ../memory-bench/README.md 'harness README'

      runner = component 'runner/' {
        #built
        description 'Drives the agent per condition; records per-run conditions + metrics'
        link ../memory-bench/membench/runner 'runner/'
      }

      bundle = component 'bundle/ + oracle/' {
        #built
        description 'Assembles oracle bundles (build, curate, consensus) and replays held-out tasks'
        link ../memory-bench/membench/bundle 'bundle/'
        link ../docs/architecture-decisions.md 'Decision 5 — replay closed beads'
      }

      arms = component 'memory_systems/ — competitive arms' {
        description 'Uniform ingest/retrieve interface; arms never read the store directly'
        link ../memory-bench/membench/memory_systems 'memory_systems/'
        link ../docs/architecture-decisions.md 'Decision 11 — competitive-arm contract'

        armsBuilt = component 'none / ours / oracle / filesystem / lexical' {
          #built
          description 'Stateless floor, failure-triggered ours, exact-memory ceiling, the filesystem baseline, and the deterministic lexical top-k arm that activates the Confusion + Staleness retrieval-quality metrics'
        }
        armsExternal = component 'mem0 / A-MEM / NAT / Graphiti' {
          #built
          description 'Third-party memory systems behind the same interface — real adapters, all on a local OSS stack (Qdrant / ChromaDB / Redis / FalkorDB + Ollama), no paid API'
        }
        armsConsolidating = component 'consolidating / retention-scheduled' {
          #built
          description 'Two-speed consolidation and TTL/retention-policy variants'
        }
        armsDeferred = component 'builtin (agent-native memory)' {
          #planned
          description 'The agent’s own built-in memory; deferred — a paid Harbor path (mem-whi), explicitly not wired into the harness'
        }
      }

      grading = component 'grading/ — gates & metrics' {
        description 'Validity gates plus the scoring stack (L1 retrieval, L2 utilization, L3 end-to-end)'
        link ../memory-bench/membench/grading 'grading/'

        leakGuard = component 'leak guard + validity gate' {
          #built
          description 'Temporal LOO leak guard; oracle ≈ no_memory rejects the task'
          link ../memory-bench/membench/grading/leak_guard.py 'leak_guard.py'
          link ../docs/architecture-decisions.md 'Decision 6 — temporal LOO'
        }
        soundness = component 'oracle-soundness gate' {
          #built
          #risk
          description 'CodeScaleBench fail-to-pass admission gate. RISK: commit-linkage recovered 407 sound work→landed-commit oracles, but only ~8 replay cleanly — the rest hit the oracle-validity wall, so the real-corpus headline runs at small N bound by replay fidelity, not method'
          link ../memory-bench/membench/grading/safety_gates.py 'safety_gates.py'
        }
        ablation = component 'ablation curve + graded scorer' {
          #evolving
          #risk
          description 'Reward-vs-information saturation curve — the headline metric. RISK: on the real corpus the graded 3-arm grid is null at usable N (ours +0.000, builtin +0.125, 8 of 407 scorable); the synthetic track carries the first measurable lift (continuity 0.062 → 0.188). Release decision on the diagnosed-ceiling negative is open (mem-1fl8)'
          link ../memory-bench/membench/grading/ablation.py 'ablation.py'
          link ../docs/architecture-decisions.md 'Decision 17/18 — ablation headline, direct-to-main'
        }
        scorers = component 'trace / judge / merged-diff scorers' {
          #built
          description 'Deterministic trace-error check, LLM-judge rubric, opportunistic merged-diff oracle'
          link ../memory-bench/membench/grading/judge.py 'judge.py'
        }
        precision = component 'precision / coverage guard' {
          #built
          description 'Injected-context volume + retrieval precision so over-injection cannot fake a win'
          link ../memory-bench/membench/grading/coverage.py 'coverage.py'
          link ../docs/architecture-decisions.md 'Decision 10 — precision guard'
        }
      }

      telemetry = component 'telemetry/ + metrics/' {
        #built
        description '5-axis vector (task, efficiency, latency, privacy, interruption) as OTel GenAI spans + ATIF'
        link ../memory-bench/membench/telemetry 'telemetry/'
        link ../docs/architecture-decisions.md 'Decision 12 — 5-axis telemetry'
      }

      generators = component 'generators/ — synthetic-world track' {
        #built
        description 'Authors seed-reproducible, memory-dependent task sequences — the track that produced the first measurable lift (cross-task continuity 0.062 → 0.188 under a shared store)'
        link ../memory-bench/membench/generators 'generators/'
        link ../docs/architecture-decisions.md 'Decision 16 — eval object + scope'

        worldBuilder = component 'NeMo world builder' {
          #built
          description 'Builds an EnterpriseWorld from a NeMo natural-language surface (personas / PRDs / repo shapes), then validates org-coherence in pure code. NeMo import is lazy + frozen offline, so the suite runs without the SDK'
          link ../memory-bench/membench/generators/nemo/world_builder.py 'nemo/world_builder.py'
        }
        workflowMaterializer = component 'enterprise-workflow materializer' {
          #built
          description 'Turns a world into multi-session sequences: every fact, distractor, and supersession authored in code and seed-reproducible, so memory necessity / Confusion / Staleness are planted, not guessed'
          link ../memory-bench/membench/generators/enterprise_workflow.py 'enterprise_workflow.py'
        }
        necessityGate = component 'memory-necessity + pilot filter' {
          #built
          description 'Rejects tasks an agent can solve without memory (oracle ≈ no_memory), and a structural pilot filter on width/shape — the synthetic analogue of the oracle-soundness gate'
          link ../memory-bench/membench/generators/memory_necessity_gate.py 'memory_necessity_gate.py'
        }
        calibration = component 'real-anchor / ftp-shape calibration' {
          #evolving
          #risk
          description 'Calibrates the synthetic generator against real fail-to-pass shapes (mem-bxhh.5). RISK: the open validity question is whether a synthetic lift generalizes to real city work — Gate-0 rank-correlation against a real anchor is currently flat / NO-GO'
          link ../memory-bench/membench/generators/external_anchor.py 'external_anchor.py'
        }
        worldFreeze = component 'world freeze + determinism manifest' {
          #built
          description 'Serializes worlds to fixtures/worlds/<seed>/ and verifies a determinism manifest, so a frozen world replays byte-identically without re-touching NeMo'
          link ../memory-bench/membench/generators/world_manifest.py 'world_manifest.py'
        }
      }

      // The synthetic corpus artifact — the frozen counterpart to gascity's
      // real audit, materialized in-repo and seed-reproducible.
      worlds = datastore 'fixtures/worlds/ — frozen synthetic worlds' {
        #built
        description 'Seed-keyed frozen NeMo worlds + determinism manifest; the synthetic corpus the harness replays from'
        link ../memory-bench/membench/generators/world_manifest.py 'world_manifest.py'
      }

      harborAdapter = component 'harbor/ — execution adapter' {
        #built
        description 'WorkRecord→task-env, memory injection, control grids, repro, env recon'
        link ../memory-bench/membench/harbor 'harbor/'
      }

      report = component 'report/ + bbon/' {
        #evolving
        description 'Per-arm vectors, comparative judge, narrative diffs, aggregate reporting'
        link ../memory-bench/membench/report 'report/'
      }
    }

    // ── Planned: the learned memory controller ─────────────────────────────
    controller = container '6-stage memory controller (MCP server)' {
      #planned
      description 'Designed; v1 fills each stage with a heuristic/judge and logs the decision so it is trainable'
      link ../.gc/memory-eval-harness-spec.md 'Harness spec §1'
      link ../docs/architecture-decisions.md 'Decision 14 — controller-loop framing'

      classify = component 'need-classification → query-formation' {
        #planned
      }
      multiRetrieve = component 'multi-type retrieval → reranking' {
        #planned
        description 'rerank_features vector logged from run one (relevance / recency / importance / trust / task-fit)'
      }
      inject = component 'minimal-useful injection' {
        #planned
      }
      writeGate = component 'post-task write decision' {
        #planned
        description 'Scored as P(future task improves | memory retrievable); dual-confidence (retrieval vs truth)'
        link ../docs/memory-prediction-and-dual-confidence.md 'write-decision & dual-confidence'
      }
    }

    // ── Research track ─────────────────────────────────────────────────────
    reranker = container 'Fine-tuning / RL reranker' {
      #research
      description 'research/ PRDs — learned reranker + retrieval behavior, trained once replay produces labels'
    }
    sequenceEval = container 'Multi-session sequence eval' {
      #planned
      description 'Sequence / convoy-epic eval object — scales past the thin real task pool'
      link ../docs/architecture-decisions.md 'Decision 16 — eval object'
    }
  }

  // ─────────────────────────────────────────────────────────────────────────
  // Relationships.
  // ─────────────────────────────────────────────────────────────────────────

  // Ingest pipeline (IO → graph)
  store.ingest.beadReader -> gascity.beadStore 'reads work spine + labels'
  store.ingest.beadReader -> github 'reads PR / commit outcome (where linked)'
  store.ingest.traceReader -> gascity.gcLogs 'resolves session → JSONL path'
  store.ingest.traceReader -> gascity.sessionTraces 'reads transcripts'
  store.ingest.landed -> github 'dates branch tip at close → landed commits (direct-to-main oracle)'
  store.ingest -> store.parse 'raw WorkRecords'

  // Parse (deterministic in code, semantic via model)
  store.parse.semantic -> models 'root-cause + resolution (batched, once per record)'
  store.parse -> store.graph 'writes signal + projections'

  // Distill + retrieve
  store.distill -> store.graph 'appends lessons'
  store.distill -> models 'distills resolutions'
  store.retrieve -> store.graph 'failure-triggered query'

  // CLI surface
  store.cli -> store.ingest 'build-store / ingest-traces'
  store.cli -> store.retrieve 'mem retrieve'
  store.cli -> store.graph 'mem query / coverage'
  store.cli -> store.distill 'mem distill-lessons'

  // Eval harness
  bench.bundle -> store.cli 'loads store via `mem query`'
  bench.runner -> bench.bundle 'runs each condition'
  bench.arms -> bench.bundle 'uniform ingest/retrieve interface'
  bench.arms.armsBuilt -> store.retrieve 'the `ours` arm fires failure-triggered retrieval'
  bench.runner -> bench.harborAdapter 'submits per-condition tasks'
  bench.harborAdapter -> harbor 'replays tasks'
  harbor -> agent 'runs the agent under test'
  bench.grading -> bench.runner 'gates + scores each run'
  bench.grading.scorers -> models 'LLM-judge rubric_score'
  bench.telemetry -> bench.runner 'emits per-run spans'
  bench.report -> bench.grading 'aggregates graded results per arm'

  // Synthetic-world track (the second corpus)
  bench.generators.worldBuilder -> nemo 'NeMo NL surface (run offline, then frozen)'
  bench.generators.worldFreeze -> bench.worlds 'freezes worlds + determinism manifest'
  bench.generators -> bench.worlds 'materializes seed-reproducible worlds'
  bench.worlds -> bench.bundle 'frozen synthetic sequences feed the task pool'
  bench.generators.calibration -> bench.grading.soundness 'calibrates synthetic shapes against real fail-to-pass oracles'

  // Planned controller wiring
  controller -> store.graph 'multi-type retrieval + write' {
    #planned
  }
  controller.classify -> controller.multiRetrieve {
    #planned
  }
  controller.multiRetrieve -> controller.inject {
    #planned
  }
  controller.inject -> controller.writeGate {
    #planned
  }
  agent -> controller 'MCP retrieve / write / reflect' {
    #planned
  }
  reranker -> controller.multiRetrieve 'learned rerank' {
    #research
  }
  sequenceEval -> bench.bundle 'multi-session task object' {
    #planned
  }
}
