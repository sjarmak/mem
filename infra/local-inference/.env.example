# Copy to .env and adjust. docker-compose reads it automatically.

# Same checkpoint on both engines so an A/B isolates the engine, not the model.
# An 8B at bf16 (~16 GB) fits the 32 GB 5090; a 3B lets both engines run side-by-side.
MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct
MAX_MODEL_LEN=8192

# Gate your HF token here for gated checkpoints (Llama etc.).
HUGGING_FACE_HUB_TOKEN=
HF_CACHE=~/.cache/huggingface

# --- Blackwell (RTX 5090, sm_120) needs CUDA 12.8+ engine images. Pin tags that ship
# it; "latest" usually works but pin once a good one is found, for reproducibility. ---
VLLM_IMAGE=vllm/vllm-openai:latest
SGLANG_IMAGE=lmsysorg/sglang:latest
DCGM_IMAGE=nvidia/dcgm-exporter:3.3.5-3.4.1-ubuntu22.04

# KV budget per engine. Lower BOTH to ~0.45 with a small model to run them at once.
VLLM_GPU_MEM_UTIL=0.85
SGLANG_MEM_FRACTION=0.85

# Quantization is a throughput axis — add `--quantization=fp8` to the vllm command (or
# serve an AWQ/GPTQ checkpoint) to free KV headroom on Blackwell. See README.
