# Gas City
.beads/*
!.beads/identity.toml

# Node
node_modules/
dist/

# Secrets — local environment / API keys (e.g. NGC_API_KEY for the local NIM)
.env
.env.*
!.env.example

# P1.5 work-audit store (generated artifact; built via `mem build-store`)
.mem/

# Internal working notes + Gas City project context (not public)
.gc/

# Paper draft — kept out of the public repo
paper/

# Day-0 perishable freeze (mem-wanz.1): commit the text index + manifest, but the
# multi-GB git bundles and in-flight partial captures are generated artifacts.
freeze/*/bundles/
freeze/*.partial-*

# Step-0 rig checkout+remote verification reports (mem-wanz.2): dated, machine-
# generated by scripts/verify-rig-checkouts.mjs — a reproducible local preflight,
# not a committed artifact.
verify/rig-checkouts.*.json

# NeMo-generated synthetic worlds (mem-t1k5): model output frozen by
# scripts/generate_worlds.py. Curated freezing + manifest is Phase 4 (mem-ge51);
# until then these are local generation artifacts, not committed.
memory-bench/fixtures/worlds/
